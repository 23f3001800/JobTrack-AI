# ============================================================
# JobTrack AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required vars are marked with [REQUIRED].
# Everything else is optional with sensible defaults.
# ============================================================

# ── LLM Provider [REQUIRED] ──
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Application Security [REQUIRED] ──
# Used for API key authentication (CLI, MCP, CI/CD).
# Generate a strong random key: openssl rand -hex 32
API_KEY=dev-secret-key-change-in-production

# ── File Paths ──
WORKSPACE_DIR=./workspace
CV_PATH=./my_cv.pdf

# ── Agent Config ──
# Max LLM iterations per agent to prevent runaway loops
MAX_AGENT_ITERATIONS=10

# ── Supabase (Optional) ──
# If not set, the app falls back to local JSON file storage.
# Get these from: https://supabase.com/dashboard → Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key
SUPABASE_ANON_KEY=eyJ...your-anon-key
# JWT secret for local token verification (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=your-jwt-secret

# ── LangSmith Observability (Optional) ──
# Get from: https://smith.langchain.com → Settings → API Keys
LANGCHAIN_API_KEY=ls_...
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=jobtrack-ai

# ── Dashboard (set in dashboard/.env.local instead) ──
# NEXT_PUBLIC_API_URL=http://localhost:8000